% neurips_2024.sty — minimal NeurIPS 2024 compatible style file
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 (minimal)]

\newif\if@preprint\@preprintfalse
\newif\if@final\@finalfalse
\newif\if@nonatbib\@nonatbibfalse

\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@finaltrue}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

\RequirePackage[
  letterpaper,top=1in,bottom=1in,left=1.25in,right=1.25in,
  headheight=14pt,headsep=0.25in,footskip=0.5in
]{geometry}

\RequirePackage[T1]{fontenc}
\RequirePackage{times}

\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}
\linespread{1.0}

\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{1.5ex plus .5ex minus .2ex}{.5ex plus .2ex}
\titlespacing*{\subsection}{0pt}{1.2ex plus .4ex minus .2ex}{.3ex plus .1ex}
\titlespacing*{\subsubsection}{0pt}{1.0ex plus .3ex minus .2ex}{.3ex plus .1ex}

\RequirePackage[font=small,labelfont=bf,labelsep=period]{caption}

\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}\vspace{0.5ex}%
  \begin{quote}\small
}{\end{quote}\vspace{1ex}}

\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\small\thepage}
\if@preprint
  \fancyhead[C]{\small\textit{Preprint. Under review.}}
\fi
\renewcommand{\headrulewidth}{0pt}

% natbib disabled: using thebibliography
\if@nonatbib\else
  %\RequirePackage{natbib}
  %\bibliographystyle{abbrvnat}
  %\setlength{\bibsep}{2pt}
\fi

\endinput
